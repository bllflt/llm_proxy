# FastAPI Configuration
DEBUG=false
LOG_LEVEL=INFO

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
HOST=0.0.0.0
PORT=8000

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
RESULT_API_ENDPOINT=http://127.0.0.1:5000/api/v1/ai/work/caption/complete
HTTP_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379

# MCP (Model Context Protocol) - Required for chat functionality
MCP_ENDPOINT=http://127.0.0.1:5000/mcp

# Chat Configuration
CHAT_HISTORY_EXPIRE_MINUTES=1440
CHAT_MODEL=gemini-2.5-flash

